# ============================================
# DATABASE & PERSISTENCE
# ============================================
DATABASE_URL="postgresql://user:password@localhost:5432/architectiq"
SHADOW_DATABASE_URL="postgresql://user:password@localhost:5432/architectiq_shadow"
REDIS_URL="redis://localhost:6379"

# ============================================
# AUTHENTICATION & JWT
# ============================================
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRATION=604800
SESSION_SECRET="your-session-secret-change-in-production"

# ============================================
# AI SERVICES & LLMs
# ============================================
OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY="sk-ant-..."
GOOGLE_GEMINI_API_KEY="..."

# ============================================
# VECTOR DATABASE (RAG & Embeddings)
# ============================================
# Qdrant (recommended)
QDRANT_URL="http://localhost:6333"
QDRANT_API_KEY=""

# Alternative: Pinecone
PINECONE_API_KEY=""
PINECONE_ENVIRONMENT="us-east1-aws"
PINECONE_INDEX_NAME="architectiq"

# ============================================
# STORAGE & FILE UPLOAD
# ============================================
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_S3_BUCKET="architectiq-uploads"
AWS_S3_ENDPOINT=""

# ============================================
# PDF INGESTION & PARSING
# ============================================
LLAMAPARSE_API_KEY=""
UNSTRUCTURED_API_KEY=""

# ============================================
# AI MICROSERVICE (FastAPI)
# ============================================
AI_SERVICE_URL="http://localhost:8000"
AI_SERVICE_API_KEY=""

# ============================================
# EXTERNAL INTEGRATIONS
# ============================================
LANGCHAIN_API_KEY=""

# ============================================
# APPLICATION CONFIGURATION
# ============================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3000/api"
NEXT_PUBLIC_SHARE_DOMAIN="architectiq.app"
NODE_ENV="development"

# ============================================
# MONITORING & LOGGING
# ============================================
# Sentry error tracking
SENTRY_DSN=""

# DataDog monitoring
DATADOG_API_KEY=""
DATADOG_ENVIRONMENT="development"

# ============================================
# FEATURE FLAGS
# ============================================
FEATURE_COLLABORATION=false
FEATURE_REAL_TIME_UPDATES=false
FEATURE_AI_EVALUATION=true
FEATURE_RAG_RETRIEVAL=true
FEATURE_AI_COPILOT=false

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=900

# ============================================
# DEBUG & DEVELOPMENT
# ============================================
DEBUG=false
NEXT_PUBLIC_DEBUG=false
PRISMA_STUDIO_PORT=5555
